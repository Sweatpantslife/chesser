# Chesser — environment configuration.
# Copy to .env and adjust. All values have sensible defaults; nothing here is
# required to boot. In Docker these are set on the container (see docker-compose.yml).
# Full reference — defaults, purpose and security notes per variable: DEPLOYMENT.md.

# ── Network ────────────────────────────────────────────────────────────────
PORT=8787
HOST=0.0.0.0
NODE_ENV=production

# ── Reverse proxy ───────────────────────────────────────────────────────────────
# How many X-Forwarded-For hops to trust, so req.ip is the real client (needed
# for the per-IP AI-coach rate limit behind Traefik/Nginx/Coolify). 1 = one
# reverse proxy (the usual setup); use a higher number or an address/CIDR list
# for deeper chains. Leave off when the server is exposed directly. The whole
# chain is never trusted blindly — the leftmost XFF entry is client-supplied
# and trusting it would let clients spoof their IP.
# TRUST_PROXY=1

# ── CORS ───────────────────────────────────────────────────────────────────
# Extra browser origins allowed to call the API cross-origin, comma-separated
# (e.g. https://chess.example.com,https://staging.example.com). Unset = no
# cross-origin browser access at all — correct for the normal single-origin
# deployment where the server serves the SPA itself.
# CHESSER_ALLOWED_ORIGINS=

# ── Logging ────────────────────────────────────────────────────────────────
# Per-request pino log lines. Defaults on when NODE_ENV=production.
# CHESSER_LOG=true
# Logger level for everything (request lines + module logs):
# fatal|error|warn|info|debug|trace|silent. Default info.
# CHESSER_LOG_LEVEL=info
# Human-readable output (pino-pretty). Defaults on for a dev TTY, off in
# production; production deploys don't ship pino-pretty, so leave this unset.
# CHESSER_LOG_PRETTY=false

# ── Observability ──────────────────────────────────────────────────────────
# GET /healthz (liveness) and GET /readyz (readiness: data dir writable, web
# assets present) are always on, unauthenticated, and kept out of logs/metrics.
# GET /metrics serves Prometheus text (http_requests_total, auth_failures_total,
# proxy_requests_total, ws_connections_current, engine_processes_current).
# It is OPEN unless this token is set; the server sits behind a single proxied
# port (no localhost-only bind to hide it on), so set a token whenever the app
# is reachable from the public internet. Scrape with
#   Authorization: Bearer <token>
# CHESSER_METRICS_TOKEN=
# Error tracking: a Sentry-compatible DSN (Sentry, GlitchTip, …). Unhandled
# 5xx errors and crashes are reported there. Unset = silent no-op.
# CHESSER_SENTRY_DSN=

# ── Persistence ────────────────────────────────────────────────────────────
# Accounts + synced progress (JSON store). Mount this on a volume in production.
CHESSER_DATA_DIR=/data

# ── Sessions ───────────────────────────────────────────────────────────────
# Bearer-token lifetime in days (sliding: each authenticated use extends it).
# Tokens created before expiry existed are backfilled to now + TTL on boot.
# CHESSER_SESSION_TTL_DAYS=30

# ── Engine resource budget (per Stockfish process) ─────────────────────────
CHESSER_THREADS=2
CHESSER_HASH_MB=128

# ── WebSocket engine-session caps ───────────────────────────────────────────
# Each /ws connection may spawn up to two Stockfish processes, so concurrent
# CONNECTIONS are capped globally and per client IP (per-IP needs TRUST_PROXY
# behind a reverse proxy, otherwise every client shares the proxy's address).
# NOTE: the web client opens one /ws per browser tab on load and holds it for
# the tab's lifetime, so every open tab — even one only reading, not analyzing —
# consumes a slot. Size these for your expected concurrent-tab count, not just
# active analyses. A refused tab is closed with 1013 and reconnects with capped
# exponential backoff (it does not hot-loop), but loses engine features until a
# slot frees. Behind a shared NAT (school/office), raise the per-IP cap.
# CHESSER_WS_MAX_SESSIONS=32
# CHESSER_WS_MAX_SESSIONS_PER_IP=8

# ── Asset / engine locations (set by the Docker image; override only if you
#    serve from non-default paths) ───────────────────────────────────────────
# CHESSER_WEB_DIR=/app/web
# CHESSER_ENGINES_DIR=/app/engines
# Repo-root override for the default path derivations above (rarely needed).
# CHESSER_ROOT=

# ── Local Syzygy tablebases (optional) ─────────────────────────────────────
# One or more directories joined the way Stockfish's SyzygyPath expects.
# CHESSER_SYZYGY_PATH=/syzygy

# ── AI Coach (optional LLM explanations) ───────────────────────────────────
# Natural-language coaching worded from the engine's analysis. Without a key
# the endpoint reports { configured: false } and the web client silently falls
# back to its built-in rule-based explanations. Anthropic wins when both keys
# are set. Responses are LRU-cached (1h) and rate-limited (20/min per IP).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Model override for either provider. Defaults: claude-haiku-4-5-20251001
# (Anthropic) / gpt-4o-mini (OpenAI-compatible).
# COACH_LLM_MODEL=
# OpenAI-compatible base URL (e.g. http://localhost:11434/v1 for Ollama).
# COACH_LLM_BASE_URL=https://api.openai.com/v1
#
# BYOK direct-call escape hatch (browsers): users can bring their own key and
# point the coach at a custom OpenAI-compatible endpoint, called DIRECTLY from
# the browser. The CSP only allows api.anthropic.com + api.openai.com by
# default, so a custom endpoint — especially a self-hosted / LAN LLM (Ollama,
# LM Studio, llama.cpp) — is blocked unless you whitelist its origin(s) here
# (comma-separated http(s) origins). Note: a browser on an https page cannot
# call a plain-http LAN endpoint (mixed content), so serve the app over http on
# the LAN, or give the endpoint TLS. Public https endpoints do not need this —
# they fall back to the server-side pass-through automatically.
# CHESSER_COACH_CONNECT_ORIGINS=http://192.168.1.50:11434

# ── External data upstreams (must be reachable from the server) ────────────
# Defaults point at the public Lichess APIs; override to self-host.
# CHESSER_TABLEBASE_URL=https://tablebase.lichess.ovh/standard
# CHESSER_EXPLORER_MASTERS_URL=https://explorer.lichess.ovh/masters
# CHESSER_EXPLORER_LICHESS_URL=https://explorer.lichess.ovh/lichess
# Lichess API token for the opening explorer — explorer.lichess.ovh requires
# authentication since 2024. SECRET: sent as a Bearer header to Lichess only;
# the /api/explorer proxy is per-IP rate-limited so visitors can't burn the
# token's quota. Without it the explorer reports itself unavailable.
# CHESSER_LICHESS_TOKEN=

# ── Coolify ────────────────────────────────────────────────────────────────
# Auto-generates a domain and wires Traefik to port 8787. Coolify sets this for
# you; listing the key (no value) in docker-compose.yml is enough.
# SERVICE_FQDN_CHESSER_8787=
